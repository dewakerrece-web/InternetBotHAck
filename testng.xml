<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="InternetBot Suite">

    <listeners>
        <listener class-name="com.InternetBotHAck.listeners.TestListener"/>
        <listener class-name="com.InternetBotHAck.listeners.ExtentReportManager"/>
    </listeners>

    <test name="Login Tests">
        <classes>
            <class name="com.InternetBotHAck.tests.LoginTest"/>
        </classes>
    </test>
    <test name="Alert Tests">
        <classes>
            <class name="com.InternetBotHAck.tests.AlertTest"/>
        </classes>
    </test>
    <test name="Checkbox Tests">
        <classes>
            <class name="com.InternetBotHAck.tests.CheckboxTest"/>
        </classes>
    </test>
    <test name="Dropdown Tests">
        <classes>
            <class name="com.InternetBotHAck.tests.DropdownTest"/>
        </classes>
    </test>
    <test name="Upload Tests">
        <classes>
            <class name="com.InternetBotHAck.tests.UploadTest"/>
        </classes>
    </test>
    <test name="Dynamic Tests">
        <classes>
            <class name="com.InternetBotHAck.tests.DynamicTest"/>
        </classes>
    </test>
</suite>